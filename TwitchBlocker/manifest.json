{
  "manifest_version": 3,
  "name": "Twitch Guard",
  "version": "1.2",
  "description": "Blendet unerwünschte Twitch-Kanäle basierend auf einer persönlichen Liste aus.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.twitch.tv/*"],
      "js": ["content.js"]
    }
  ],
  "host_permissions": [
    "*://*.twitch.tv/*"
  ]
}